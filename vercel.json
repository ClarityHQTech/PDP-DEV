{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/auth/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/v1/history",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/v1/history/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/v1/detect-url",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/report/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/site-report/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/components/(.*)",
      "destination": "/public/components/$1"
    },
    {
      "source": "/index.css",
      "destination": "/public/index.css"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}
