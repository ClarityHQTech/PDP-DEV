# ── LLM Keys (at least ONE required) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude Haiku (primary)
GEMINI_API_KEY=AIza...                # Gemini 2.5 Flash Lite (fallback)

# ── Scraping (optional but recommended) ──────────────────────────────────────
JINA_API_KEY=jina_...                 # Jina Reader for better markdown extraction

# ── Auth ─────────────────────────────────────────────────────────────────────
DEV_AUTH_BYPASS=true                  # Set false in production
SECRET_KEY=changeme-replace-in-prod

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
